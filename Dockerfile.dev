FROM golang:1.26.0-bookworm@sha256:878786d2372335058513ce271a4a5c2a1d3e6839b105144183464a05558b101c AS go


FROM node:25-bookworm@sha256:ee8da47d6d7cdce02f246d7363dad4f687340854ab161816ce1bc3ce5ff1069b

COPY --from=go /usr/local/go /usr/local/go

ARG uid
ARG gid

ENV CGO_ENABLED=0
ENV GOPATH="/go"
ENV GOCACHE="/go-cache"
ENV PATH="/go/bin:/usr/local/go/bin:$PATH"

RUN install -d --owner=${uid} --group=${gid} \
    /home/node/.npm \
    /go \
    /go-cache \
    /database

USER ${uid}:${gid}

WORKDIR /application
